# CONFIGURAÇÃO DO PROSPECTRAR
# Ativa integração real com LDB
VITE_USE_REAL_DATA=true

# Configurações de desenvolvimento
VITE_NODE_ENV=development

# API Keys (adicionar quando necessário)
# VITE_LDB_API_KEY=

# URLs de desenvolvimento
VITE_APP_URL=http://localhost:5173

# Debug e logs
VITE_DEBUG_MODE=true
VITE_LOG_LEVEL=info

# Cache settings
VITE_CACHE_DURATION=43200000
